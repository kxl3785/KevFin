PORT=3001

# Real-Time Zillow Data API key — https://www.openwebninja.com
OPENWEBNINJA_KEY=your_openwebninja_key

# Plaid (used only for Frec + Bilt). OAuth institutions require Production.
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=production

# Override the SQLite DB path (default resolves to /app/data/kevfin.db in the
# container, which lands on the mounted host volume — no change needed normally).
# DB_PATH=/app/data/kevfin.db

# Set to false to disable the automatic midnight net-worth snapshot cron.
# DAILY_SNAPSHOT=false
