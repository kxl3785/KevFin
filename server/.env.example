PORT=3001
# Real-Time Zillow Data API key from https://www.openwebninja.com
OPENWEBNINJA_KEY=your_openwebninja_key

# Plaid (used only for Frec + Bilt). OAuth institutions require Production.
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=production

# The AI assistant runs on your local Claude Code login (no API key needed).
# Only set this if the binary isn't auto-detected — point it at the executable:
# CLAUDE_BIN=/usr/local/bin/claude
